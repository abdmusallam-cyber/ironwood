rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- CORE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == 'abd.musallam@gmail.com'.lower()) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- USERS ---
    // Registration + login resolve username/email via Firestore before auth.
    // Do not require orderBy.size() == 0: clients may send an implicit __name__ order,
    // which would deny all public lookups and break sign-up with PERMISSION_DENIED.
    function isPublicUserQuery() {
      return request.query.limit == 1
        && request.query.where.size() == 1
        && request.query.where[0].fieldPath in ['username', 'email', 'displayName'];
    }

    match /users/{userId} {
      allow list: if isSignedIn() || isPublicUserQuery();
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Allow other collections as needed
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin();
    }

    match /portfolio/{portfolioId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /homeHighlights/{highlightId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    match /shippingRates/{rateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}